// Prisma schema for Neon Postgres
// Run: npx prisma generate && npx prisma migrate dev

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Project {
  id           Int      @id @default(autoincrement())
  title        String
  description  String?
  technologies String[]
  /// Source repository (e.g. GitHub, GitLab).
  repoUrl      String?
  /// Deployed app / demo (e.g. Vercel).
  liveUrl      String?
  datePublished DateTime?
  category     String?
  screenshots  String[]
  outcomes     String[]
  challenges   String[]
  caseStudy    String?
  slug         String   @unique
  viewCount    Int      @default(0)
}
