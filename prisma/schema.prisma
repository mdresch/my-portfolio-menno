// Prisma schema for Neon Postgres
// Run: npx prisma generate && npx prisma migrate dev

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Project {
  id           Int      @id @default(autoincrement())
  title        String
  description  String?
  technologies String[]
  /// Source repository (e.g. GitHub, GitLab).
  repoUrl      String?
  /// Deployed app / demo (e.g. Vercel).
  liveUrl      String?
  datePublished DateTime?
  category     String?
  screenshots  String[]
  outcomes     String[]
  challenges   String[]
  caseStudy    String?
  slug         String   @unique
  viewCount    Int      @default(0)
}

/// Curated image library (blog covers, projects, direct links). Served at /media/{slug}.
model ImageAsset {
  id          String      @id @default(cuid())
  slug        String      @unique
  storageKey  String
  blobUrl     String?
  filename    String
  mimeType    String
  byteSize    Int
  width       Int?
  height      Int?
  altText     String?
  title       String?
  caption     String?
  description String?
  tags        String[]    @default([])
  source      String      @default("upload")
  checksum    String?     @unique
  deletedAt   DateTime?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  views       ImageView[]

  @@index([deletedAt])
  @@index([createdAt])
}

model ImageView {
  id         String     @id @default(cuid())
  imageId    String
  image      ImageAsset @relation(fields: [imageId], references: [id], onDelete: Cascade)
  occurredAt DateTime   @default(now())
  referrer   String?
  path       String?
  userAgent  String?
  isBot      Boolean    @default(false)

  @@index([imageId, occurredAt])
}
