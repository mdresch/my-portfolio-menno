# ============================================
# Environment Variables Template
# ============================================
# Copy this file to .env.local or .env and fill in your actual values
# Never commit .env or .env.local to git (they're in .gitignore)

# ============================================
# Database Configuration (REQUIRED)
# ============================================

# Neon PostgreSQL Database Connection
# Get your connection string from: https://console.neon.tech
# Format: postgresql://username:password@host:port/database?sslmode=require&channel_binding=require
# Leave empty here — set the real value only in .env / .env.local (never commit secrets).
DATABASE_URL=""

# IMPORTANT: Replace with your actual Neon connection string from https://console.neon.tech
# Example format (DO NOT USE - This is just for reference):
# DATABASE_URL="postgresql://user:pass@ep-xxx-pooler.region.aws.neon.tech/dbname?sslmode=require&channel_binding=require"

# Alternative: Direct connection (non-pooler) if pooler has issues
# DATABASE_URL="postgresql://username:password@host:port/database?sslmode=require"
#
# If dev logs show prisma:error … connection Closed: the server closed an idle TCP
# link. Prefer the Neon *-pooler* host (see above). You can add e.g. &connect_timeout=15
# to the query string. Optional: PRISMA_LOG_QUERIES=1 enables query logs in development.

# ============================================
# Backend API Configuration (OPTIONAL)
# ============================================

# URL for separate .NET Core API backend (if using)
# NEXT_PUBLIC_API_BASE_URL="http://localhost:5154/api"
# NEXT_PUBLIC_API_BASE_URL="https://your-api-domain.azurecontainerapps.io/api"

# ============================================
# Firebase — Web / client (REQUIRED for browser Auth, login, signup)
# ============================================
# Next.js only exposes variables to the browser if the name starts with NEXT_PUBLIC_.
# Putting apiKey / projectId in the service account JSON or as FIREBASE_* without
# NEXT_PUBLIC_ will NOT fix client login — you must add the Web SDK snippet here.
#
# Firebase Console → Project settings → General → Your apps → Web app →
# "npm" / "Config" shows firebaseConfig = { apiKey, authDomain, ... }. Map like this:
#
#   apiKey            → NEXT_PUBLIC_FIREBASE_API_KEY
#   authDomain        → NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN
#   projectId         → NEXT_PUBLIC_FIREBASE_PROJECT_ID
#   storageBucket     → NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET
#   messagingSenderId → NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID
#   appId             → NEXT_PUBLIC_FIREBASE_APP_ID
#   measurementId     → NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID   (optional)
#
# Prefer .env.local for secrets. After changes: restart `pnpm dev`.
# Diagnostic (names only): GET /api/health/firebase-web
#
# BFF auth (login/signup) calls Google Identity Toolkit from the server using your Web API key.
# Optional duplicate for clarity (same value as NEXT_PUBLIC_FIREBASE_API_KEY):
# FIREBASE_WEB_API_KEY="your-firebase-api-key"
# Session cookies are verified with Firebase Admin — keep FIREBASE_SERVICE_ACCOUNT_JSON set.

# NEXT_PUBLIC_FIREBASE_API_KEY="your-firebase-api-key"
# NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN="your-project.firebaseapp.com"
# NEXT_PUBLIC_FIREBASE_PROJECT_ID="your-project-id"
# NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET="your-project.appspot.com"
# NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID="123456789"
# NEXT_PUBLIC_FIREBASE_APP_ID="1:123456789:web:your-app-id"
# NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID="G-XXXXXXXXXX"

# Firebase Admin SDK (server-only; never expose to the browser)
# Download JSON: Firebase Console → Project settings → Service accounts → Generate new private key
# The `client_email` often looks like: firebase-adminsdk-xxxxx@<project>.iam.gserviceaccount.com
# Paste the entire JSON as a single line (escape quotes if needed), or use Vercel's multiline secret.
# FIREBASE_SERVICE_ACCOUNT_JSON='{"type":"service_account","project_id":"...","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"firebase-adminsdk-...@....iam.gserviceaccount.com",...}'
#
# If you already use the same key for Vertex / GCP, this is optional — Admin also reads:
# GOOGLE_SERVICE_ACCOUNT_KEY (same JSON content as above)
#
# After editing .env / .env.local: restart the dev server.
# GET /api/health/firebase-admin  → { "firebaseAdmin": true }  (service account JSON)
# GET /api/health/firebase-web     → { "missingEnvKeys": [...] } (NEXT_PUBLIC_* web config)
#
# Journey chat (/friends-contact/journey → Message Menno; replies in /admin/journey-inbox)
# Requires Firestore enabled on the same Firebase project as Admin JSON above.
# Comma-separated login emails (must match Firebase BFF session email) allowed to read inbox + send replies:
# JOURNEY_CHAT_ADMIN_EMAILS="you@example.com"

# ============================================
# Google Cloud / Vertex AI (OPTIONAL)
# ============================================
# Only needed if using AI/ML features

# GOOGLE_CLOUD_PROJECT_ID="your-project-id"
# VERTEX_AI_PROJECT_ID="your-project-id"
# GOOGLE_CLOUD_LOGGING_DISABLED="true"

# ============================================
# GitHub Integration (OPTIONAL)
# ============================================
# Only needed if using GitHub API features

# GITHUB_TOKEN="ghp_your_github_personal_access_token"
# REQUIREMENTS_AGENT_TOKEN="your-requirements-agent-token"

# ============================================
# Application Configuration (OPTIONAL)
# ============================================

# Node Environment (automatically set by Next.js/Vercel)
# NODE_ENV="development"

# Next.js Telemetry (disable if desired)
# NEXT_TELEMETRY_DISABLED="1"

# ============================================
# Development Tools (OPTIONAL)
# ============================================

# Prisma Studio Port (default: 5555)
# PRISMA_STUDIO_PORT="5555"

# ============================================
# Notes
# ============================================
# 
# 1. For local development:
#    - Create .env.local (takes precedence over .env)
#    - Use your Neon connection string
# 
# 2. For Vercel deployment:
#    - Add environment variables in Vercel dashboard
#    - Go to: Project Settings > Environment Variables
#    - Set DATABASE_URL for Production, Preview, and Development
# 
# 3. Security:
#    - Never commit .env or .env.local files
#    - Use different connection strings for dev/staging/prod
#    - Rotate database passwords regularly
# 
# 4. Testing:
#    - Run: npm run test:db to test database connection
#    - Run: npx prisma studio to view database in browser

